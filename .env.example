# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# SUPABASE: Required for database and authentication.
# Get these from your Supabase Project Settings -> API.
# Example: https://pdxpfzwvrtxytptuczsp.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PRISMA: Connection string for Supabase database (PostgreSQL).
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.pdxpfzwvrtxytptuczsp.supabase.co:5432/postgres
DATABASE_URL=
DIRECT_URL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
